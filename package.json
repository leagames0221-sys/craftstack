{
  "name": "craftstack",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack portfolio monorepo: Boardly (realtime multi-tenant kanban) + Knowlex (single-tenant RAG MVP; workspace schema partitioning shipped per ADR-0047 partial in v0.5.0; auth-gated access control deferred to v0.5.4 once Auth.js lands)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:collab": "turbo run dev --filter=collab",
    "dev:knowledge": "turbo run dev --filter=knowledge",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "turbo run db:migrate",
    "demo:auth": "pnpm --filter collab demo:auth",
    "demo:record": "pnpm --filter collab demo:record",
    "demo:convert": "node scripts/demo/demo-convert.mjs",
    "demo:tts": "node scripts/demo/demo-tts.mjs",
    "demo:compose": "node scripts/demo/demo-compose.mjs",
    "demo:all": "pnpm demo:record && pnpm demo:convert && pnpm demo:tts && pnpm demo:compose",
    "demo:knowlex:record": "pnpm --filter knowledge demo:record",
    "demo:knowlex:convert": "cross-env DEMO_APP=knowledge DEMO_DIR=scripts/demo-knowlex node scripts/demo/demo-convert.mjs",
    "demo:knowlex:tts": "cross-env DEMO_DIR=scripts/demo-knowlex node scripts/demo/demo-tts.mjs",
    "demo:knowlex:compose": "cross-env DEMO_DIR=scripts/demo-knowlex node scripts/demo/demo-compose.mjs",
    "demo:knowlex:all": "pnpm demo:knowlex:record && pnpm demo:knowlex:convert && pnpm demo:knowlex:tts && pnpm demo:knowlex:compose",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "check:free-tier": "node scripts/check-free-tier-compliance.mjs",
    "attack:sim": "node scripts/attack-simulation.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,json,yaml,yml,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.0",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3"
  }
}
