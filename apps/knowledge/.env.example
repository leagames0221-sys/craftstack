# Knowlex local-dev template. Copy to `.env` and fill in.
# `.env` is git-ignored.
#
# IMPORTANT: `prisma.config.ts` prefers DIRECT_DATABASE_URL over
# DATABASE_URL. If you run `prisma migrate deploy` against a remote DB
# (Neon, RDS, ...) make sure **DIRECT_DATABASE_URL** is set to the
# Direct (non-pooled) URL, or the migration will silently target the
# value here. For local docker-compose pgvector the two are identical.

# --- Database ---------------------------------------------------------
# App runtime URL (pooled connection is fine for app traffic).
DATABASE_URL="postgresql://app:app@localhost:5432/knowlex?schema=public"

# Direct / non-pooled connection. Required for Prisma DDL
# (`migrate dev`, `migrate deploy`). For Neon, take the "Direct
# connection" string from the dashboard.
DIRECT_DATABASE_URL="postgresql://migrator:migrator@localhost:5432/knowlex?schema=public"

# --- Auth (not wired into the MVP Ask/Ingest pages yet) ---------------
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI ---------------------------------------------------------------
# Required for ingest (embedding) and ask (retrieval + generation).
# Create at https://aistudio.google.com/app/apikey. Keep billing off.
GEMINI_API_KEY=
# Optional future rerank step.
COHERE_API_KEY=

# --- Observability (optional, DSN-gated) ------------------------------
# When set, the instrumentation hook in src/instrumentation.ts boots
# the Sentry Node SDK at request time. Leave blank to skip entirely
# — the app runs unchanged.
SENTRY_DSN=
# 0..1; default 0.1 (10% of traces sampled).
SENTRY_TRACES_SAMPLE_RATE=

# --- Cost guard overrides (optional) ----------------------------------
# Defaults live in src/lib/global-budget.ts: 800/day, 10000/month.
KB_BUDGET_PER_DAY=
KB_BUDGET_PER_MONTH=

# --- Storage (planned, not used by the MVP) ---------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
