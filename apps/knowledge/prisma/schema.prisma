// Knowlex MVP schema.
//
// This is the *minimal* viable shape for the v0.3.1 MVP: paste text →
// chunk → embed → pgvector kNN → RAG-streamed Gemini Flash answer.
//
// The fuller design-phase schema (tenants, folders, document versions,
// conversations, citations, audit, billing) is preserved as
// `schema.design.prisma.bak` for reference. Re-introducing pieces is a
// matter of copying models back in one at a time, not rewriting.

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma-knowlex/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// -------------------------------------------------------------------
//  Auth.js v5 tables (User / Account / Session / VerificationToken).
//
//  Shipped in v0.5.12 (ADR-0061) — closes the access-control half of
//  ADR-0047 § Status (deferred since v0.5.0 schema partitioning).
//  Mirrors the apps/collab Auth.js setup so the two apps share the
//  same provider configuration patterns; data is per-app (separate
//  Neon databases per ADR-0018).
// -------------------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -------------------------------------------------------------------
//  Workspace — tenant boundary.
//
//  History:
//    v0.5.0: schema partitioning shipped (single `wks_default_v050`
//      demo workspace, every Document backfilled). ADR-0047 partial.
//    v0.5.12: WorkspaceMember + auth-gated route guards shipped via
//      ADR-0061 (this migration). The demo workspace stays
//      anonymously readable via `wks_default_v050` allowlist in
//      `requireWorkspaceMember` / `requireDemoOrMember`; signed-in
//      users get their own personal workspace and authed-only access
//      to it. Closes I-01 honest-disclose.
// -------------------------------------------------------------------
model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  documents Document[]
  members   Membership[]
}

// -------------------------------------------------------------------
//  Membership — user × workspace × role.
//
//  Role is a free-string column (not an enum) for forward
//  compatibility; current values are "OWNER" / "EDITOR" / "VIEWER"
//  with the same semantics as apps/collab's RBAC ladder per
//  ADR-0023. The Knowlex MVP only checks "any membership" for
//  now (ADR-0061 § Scope); finer-grained role gates are a v0.6.0+
//  candidate alongside the read-only viewer-of-shared-workspace flow.
// -------------------------------------------------------------------
model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("OWNER")
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

// -------------------------------------------------------------------
//  Documents — a blob of text the user has ingested.
// -------------------------------------------------------------------
model Document {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  content     String // full pasted text, for reference / re-chunk / preview
  charCount   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks    Chunk[]

  @@index([createdAt])
  @@index([workspaceId, createdAt])
}

// -------------------------------------------------------------------
//  Chunks — the retrieved unit for RAG.
// -------------------------------------------------------------------
model Chunk {
  id         String   @id @default(cuid())
  documentId String
  ordinal    Int // order within the parent document, 0-based
  content    String
  tokenCount Int
  createdAt  DateTime @default(now())

  // ADR-0063 hybrid retrieval (closes ADR-0011 deferred). Generated
  // tsvector maintained by Postgres on every insert/update via the
  // 20260428_chunk_fts migration. Queried via raw SQL with @@ operator
  // and ranked by ts_rank_cd; not used through Prisma's typed client
  // (the Unsupported wrapper is sufficient for migrate-deploy parity).
  tsv Unsupported("tsvector")?

  document  Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embedding Embedding?

  @@unique([documentId, ordinal])
  @@index([documentId])
}

// -------------------------------------------------------------------
//  Embeddings — pgvector 768-dim cosine over an HNSW index.
//  Vectors come from `gemini-embedding-001` with the AI-SDK
//  `providerOptions.google.outputDimensionality = 768` knob, so the
//  native 3072-dim output is truncated to fit this column without a
//  re-migration. Index type and rationale: see docs/adr/0041.
// -------------------------------------------------------------------
model Embedding {
  chunkId String @id

  // Embedding model identifier + dimensionality are stored for
  // forward-compatibility when we rotate the embedder.
  model String
  dim   Int

  // pgvector native type. Read via raw SQL for cosine kNN:
  //   SELECT chunkId FROM "Embedding"
  //   ORDER BY embedding <=> $queryVec::vector
  //   LIMIT 8
  embedding Unsupported("vector(768)")

  createdAt DateTime @default(now())

  chunk Chunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
}
