// Knowlex MVP schema.
//
// This is the *minimal* viable shape for the v0.3.1 MVP: paste text →
// chunk → embed → pgvector kNN → RAG-streamed Gemini Flash answer.
//
// The fuller design-phase schema (tenants, folders, document versions,
// conversations, citations, audit, billing) is preserved as
// `schema.design.prisma.bak` for reference. Re-introducing pieces is a
// matter of copying models back in one at a time, not rewriting.

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma-knowlex/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// -------------------------------------------------------------------
//  Documents — a blob of text the user has ingested.
// -------------------------------------------------------------------
model Document {
  id        String   @id @default(cuid())
  title     String
  content   String // full pasted text, for reference / re-chunk / preview
  charCount Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks Chunk[]

  @@index([createdAt])
}

// -------------------------------------------------------------------
//  Chunks — the retrieved unit for RAG.
// -------------------------------------------------------------------
model Chunk {
  id         String   @id @default(cuid())
  documentId String
  ordinal    Int // order within the parent document, 0-based
  content    String
  tokenCount Int
  createdAt  DateTime @default(now())

  document  Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embedding Embedding?

  @@unique([documentId, ordinal])
  @@index([documentId])
}

// -------------------------------------------------------------------
//  Embeddings — pgvector 768-dim cosine over an HNSW index.
//  Vectors come from `gemini-embedding-001` with the AI-SDK
//  `providerOptions.google.outputDimensionality = 768` knob, so the
//  native 3072-dim output is truncated to fit this column without a
//  re-migration. Index type and rationale: see docs/adr/0041.
// -------------------------------------------------------------------
model Embedding {
  chunkId String @id

  // Embedding model identifier + dimensionality are stored for
  // forward-compatibility when we rotate the embedder.
  model String
  dim   Int

  // pgvector native type. Read via raw SQL for cosine kNN:
  //   SELECT chunkId FROM "Embedding"
  //   ORDER BY embedding <=> $queryVec::vector
  //   LIMIT 8
  embedding Unsupported("vector(768)")

  createdAt DateTime @default(now())

  chunk Chunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
}
