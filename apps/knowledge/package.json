{
  "name": "knowledge",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "postinstall": "prisma generate",
    "start": "next start --port 3001",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "cross-env KNOWLEX_INTEGRATION=1 vitest run",
    "bench": "tsx scripts/bench-retrieve.ts",
    "eval": "tsx scripts/eval.ts",
    "cleanup-corpus": "node scripts/cleanup-corpus.mjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/smoke",
    "demo:record": "playwright test --config=playwright.demo.config.ts --project=record"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@sentry/nextjs": "^10.50.0",
    "ai": "^6.0.168",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
