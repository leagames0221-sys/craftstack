{
  "name": "collab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "build": "prisma generate && next build",
    "analyze": "cross-env ANALYZE=true pnpm build",
    "start": "next start --port 3000",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test --config=playwright.auth.config.ts",
    "test:e2e:install": "playwright install --with-deps chromium",
    "demo:auth": "playwright test --config=playwright.demo.config.ts --project=setup",
    "demo:record": "playwright test --config=playwright.demo.config.ts --project=record",
    "db:seed": "tsx prisma/seed.ts",
    "generate:api-types": "tsx scripts/generate-api-types.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@auth/prisma-adapter": "^2.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.50.0",
    "ai": "^6.0.168",
    "cmdk": "^1.1.1",
    "lexorank": "^1.0.5",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.20.0",
    "pusher": "^5.3.3",
    "pusher-js": "^8.5.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "openapi-typescript": "^7.13.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
