{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "passThroughEnv": [
        "DATABASE_URL",
        "DIRECT_DATABASE_URL",
        "GEMINI_API_KEY",
        "SENTRY_AUTH_TOKEN",
        "TENANCY_ENABLED",
        "ENABLE_OBSERVABILITY_API",
        "EMERGENCY_STOP"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "db:migrate": {
      "cache": false
    }
  }
}
