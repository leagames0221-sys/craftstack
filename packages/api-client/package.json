{
  "name": "@craftstack/api-client",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate:collab": "openapi-typescript ../../docs/api/collab-openapi.yaml -o ./src/collab.d.ts || echo 'no spec yet'",
    "generate:knowledge": "openapi-typescript ../../docs/api/knowledge-openapi.yaml -o ./src/knowledge.d.ts || echo 'no spec yet'",
    "generate": "pnpm generate:collab && pnpm generate:knowledge"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
